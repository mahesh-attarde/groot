#! /bin/bash
source "$(dirname "$0")/.gitrc"
if [[ -n "$1" ]]; then
    echo -e "$GIT_TAG Adding $@..."
    git add "$@" && echo -e "$GIT_TAG_OK Added." || echo -e "$GIT_TAG_ERR Add failed."
else
    echo -e "$GIT_TAG Adding all changes..."
    git add -A && echo -e "$GIT_TAG_OK Added all." || echo -e "$GIT_TAG_ERR Add failed."
fi
